const articleByHref = new Map(articles.map((article) => [article.href, article]));
const groupedHrefs = articleGroups.flatMap((section) => section.hrefs);
const missingArticles = groupedHrefs.filter((href) => !articleByHref.has(href));
const duplicateHrefs = groupedHrefs.filter(
  (href, index) => groupedHrefs.indexOf(href) !== index,
);
const unlistedArticles = articles.filter(
  (article) => !groupedHrefs.includes(article.href),
);

if (
  missingArticles.length > 0 ||
  duplicateHrefs.length > 0 ||
  unlistedArticles.length > 0
) {
  throw new Error(
    [
      missingArticles.length > 0
        ? `Missing article data: ${missingArticles.join(", ")}`
        : "",
      duplicateHrefs.length > 0
        ? `Duplicate article entries: ${duplicateHrefs.join(", ")}`
        : "",
      unlistedArticles.length > 0
        ? `Unlisted articles: ${unlistedArticles
            .map((article) => article.href)
            .join(", ")}`
        : "",
    ]
      .filter(Boolean)
      .join(" "),
  );
}

const sectionId = (title) =>
  `ai-assisted-math-${title
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "")}`;

const articleSections = articleGroups.map((section) => ({
  id: sectionId(section.title),
  title: section.title,
  articles: section.hrefs.map((href) => articleByHref.get(href)),
}));
---

<BaseLayout
  title="AI-assisted math"
  description="AI-assisted, AI-driven, and AI-authored mathematics."
  currentPath="/ai-assisted-math.html"
>
  <main class="shell article-shell">
    <article class="plain-page">
      <h1>Ai-assisted math</h1>

      <p>
        This section contains ai-assisted, ai-driven, and/or ai-authored and
        reviewed mathematics.
      </p>
      <p>
        Most articles should be considered drafts, as the math may have been only
        partially reviewed, and it could be in some cases only ai-reviewed.
        Nonetheless, I share whatever I feel could be useful to somebody, even if
        it still needs lots of work.
      </p>
      <p>
        I also aim to share prompts, handoff notes, and the original ideas that
        led the ai to the proofs.
      </p>
      <p>
        I mainly use ChatGPT 5.5 as of June 2026.
      </p>

      <section class="article-sections" aria-label="AI-assisted math articles">
        {
          articleSections.map((section) => (
            <section class="article-section" aria-labelledby={section.id}>
              <h2 id={section.id}>{section.title}</h2>
              <div class="article-list">
                {section.articles.map((article) => (
                  <a class="article-list-item" href={article.href}>
                    <time datetime={article.datetime}>{article.date}</time>
                    <span>{article.title}</span>
                    <p>{article.description}</p>
                  </a>
                ))}
              </div>
            </section>
          ))
        }
      </section>
    </article>
  </main>
</BaseLayout>
