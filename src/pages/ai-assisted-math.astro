<BaseLayout
  title="AI-assisted math"
  description="AI-assisted, AI-driven, and AI-authored mathematics."
  currentPath="/ai-assisted-math.html"
>
  <main class="shell article-shell">
    <article class="plain-page">
      <h1>Ai-assisted math</h1>

      <p>
        This section contains ai-assisted, ai-driven, and/or ai-authored and
        reviewed mathematics.
      </p>
      <p>
        Most articles should be considered drafts, as the math may have been only
        partially reviewed, and it could be in some cases only ai-reviewed.
        Nonetheless, I share whatever I feel could be useful to somebody, even if
        it still needs lots of work.
      </p>
      <p>
        I also aim to share prompts, handoff notes, and the original ideas that
        led the ai to the proofs.
      </p>
      <p>
        I mainly use ChatGPT 5.5 as of June 2026.
      </p>

      <section class="article-list" aria-label="AI-assisted math articles">
        {
          articles.map((article) => (
            <a class="article-list-item" href={article.href}>
              <time datetime={article.datetime}>{article.date}</time>
              <span>{article.title}</span>
              <p>{article.description}</p>
            </a>
          ))
        }
      </section>
    </article>
  </main>
</BaseLayout>
