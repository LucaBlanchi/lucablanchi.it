---
import DraftCard from "../components/DraftCard.astro";
import { drafts } from "../data/drafts";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Draft concepts"
  description="Bilingual draft concepts and working notes by Luca Blanchi, covering games, storage, chess encoding, large numbers, primes, and meta theory."
  currentPath="/drafts.html"
>
  <main class="shell index-shell">
    <header class="site-header">
      <h1>Draft concepts</h1>
    </header>

    <section class="draft-grid" aria-label="Draft concepts">
      {drafts.map((draft) => <DraftCard draft={draft} />)}
    </section>
  </main>
</BaseLayout>
