---
import { presentationTheoryArticleGroups, presentationTheoryArticles } from "../data/presentationTheoryArticles";
import BaseLayout from "../layouts/BaseLayout.astro";

const articles = presentationTheoryArticles;
const articleGroups = presentationTheoryArticleGroups;

const articleByHref = new Map(articles.map((article) => [article.href, article]));
const groupedHrefs = articleGroups.flatMap((section) => section.hrefs);
const missingArticles = groupedHrefs.filter((href) => !articleByHref.has(href));
const duplicateHrefs = groupedHrefs.filter(
  (href, index) => groupedHrefs.indexOf(href) !== index,
);
const unlistedArticles = articles.filter(
  (article) => !groupedHrefs.includes(article.href),
);

if (
  missingArticles.length > 0 ||
  duplicateHrefs.length > 0 ||
  unlistedArticles.length > 0
) {
  throw new Error(
    [
      missingArticles.length > 0
        ? `Missing article data: ${missingArticles.join(", ")}`
        : "",
      duplicateHrefs.length > 0
        ? `Duplicate article entries: ${duplicateHrefs.join(", ")}`
        : "",
      unlistedArticles.length > 0
        ? `Unlisted articles: ${unlistedArticles
            .map((article) => article.href)
            .join(", ")}`
        : "",
    ]
      .filter(Boolean)
      .join(" "),
  );
}

const sectionId = (title) =>
  `presentation-theory-${title
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "")}`;

const articleSections = articleGroups.map((section) => ({
  id: sectionId(section.title),
  title: section.title,
  articles: section.hrefs.map((href) => articleByHref.get(href)),
}));
---

<BaseLayout
  title="Presentation theory"
  description="Preliminary AI-assisted mathematical research notes by Luca Blanchi on presentation theory, observables, fibres, normal forms, algebraic complexity, groups, arithmetic dynamics, and proof strategies."
  currentPath="/presentation-theory.html"
>
  <main class="shell article-shell">
    <article class="plain-page">
      <h1>Presentation theory</h1>

      <p>
        This page contains articles related to a mathematics research program at
        a preliminary stage. The following articles, as of now, have been mostly
        edited and reviewed by AI. The research itself has also been
        AI-assisted, mainly with GPT-5.5. The articles do contain valuable
        mathematical content, but please keep in mind that they may contain
        mistakes, be incomplete, or be confusing, as often they are published in
        order to feed them back to the AI for further research.
      </p>

      <p class="source-note">
        Machine-readable indexes are available for citation and retrieval:
        <a href="/llms.txt">llms.txt</a>,
        <a href="/llms-full.txt">llms-full.txt</a>, and
        <a href="/citations.json">citations.json</a>.
      </p>

      <section class="article-sections" aria-label="Presentation theory articles">
        {
          articleSections.map((section, index) => (
            <details class="article-section" open={index === 0}>
              <summary id={section.id}>
                <span>{section.title}</span>
                <small>{section.articles.length} articles</small>
              </summary>
              <div class="article-list">
                {section.articles.map((article) => (
                  <a class="article-list-item" href={article.href}>
                    <time datetime={article.datetime}>{article.date}</time>
                    <span>{article.title}</span>
                    <p>{article.description}</p>
                  </a>
                ))}
              </div>
            </details>
          ))
        }
      </section>
    </article>
  </main>
</BaseLayout>
