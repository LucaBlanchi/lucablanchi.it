---
import { readFileSync } from "node:fs";
import AiAssistedMathNotice from "../../components/AiAssistedMathNotice.astro";
import SectionBackLink from "../../components/SectionBackLink.astro";
import SourceDisclosure from "../../components/SourceDisclosure.astro";
import { complexitySources } from "../../data/aiAssistedMathComplexitySources";
import { renderTexPaper } from "../../lib/texPaper";
import BaseLayout from "../../layouts/BaseLayout.astro";

const assetBase = "/assets/ai-assisted-math/foundations-presentation-complexity";
const stem = "foundations-presentation-complexity";
const paper = renderTexPaper(readFileSync(`public${assetBase}/${stem}.tex`, "utf8"), {
  idPrefix: "presentation-complexity",
});

const pdfHref = `${assetBase}/${stem}.pdf`;
const texHref = `${assetBase}/${stem}.tex`;
---

<BaseLayout
  title="Foundations of Presentation Complexity"
  description="A preliminary AI-assisted note introducing presentation systems, bounded parts, cost-controlled maps, observables, and observer-cost barriers."
  currentPath="/ai-assisted-math/a-theory-about-complexity.html"
  bodyClass="paper-surface"
>
  <script is:inline>
    window.MathJax = {
      tex: {
        inlineMath: [["\\(", "\\)"], ["$", "$"]],
        displayMath: [["\\[", "\\]"]],
      },
    };
  </script>
  <script is:inline async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js"></script>

  <main class="shell article-shell">
    <article class="plain-page ai-article paper-page">
      <SectionBackLink href="/ai-assisted-math.html" label="Back to AI-assisted math" />
      <AiAssistedMathNotice />

      <header class="plain-header paper-header">
        <div class="article-meta">
          <time datetime="2026-06">June 2026</time>
        </div>
        <h1>{paper.title}</h1>
        <p class="paper-author">{paper.author}</p>
        <div class="paper-actions" aria-label="Downloads">
          <a href={pdfHref} download>Download PDF</a>
          <a href={texHref} download>Download TeX</a>
        </div>
      </header>

      <section class="paper-abstract" aria-labelledby="abstract-title">
        <h2 id="abstract-title">Abstract</h2>
        <div set:html={paper.abstractHtml} />
      </section>

      <nav class="paper-toc" aria-labelledby="contents-title">
        <h2 id="contents-title">Contents</h2>
        <ol>
          {
            paper.tocEntries.map((entry) => (
              <li class={entry.level === "subsection" ? "paper-toc-subsection" : undefined}>
                <a href={`#${entry.id}`}>
                  <span>{entry.number}</span>
                  {entry.title}
                </a>
              </li>
            ))
          }
        </ol>
      </nav>

      <div class="paper-body" set:html={paper.bodyHtml} />

      <section class="paper-references" aria-label={`${paper.title} references`}>
        <h2>References</h2>
        <div set:html={paper.bibliographyHtml} />
      </section>

      <section class="source-notes" aria-labelledby="source-notes-title">
        <h2 id="source-notes-title">Ideas, philosophy, and handoff notes</h2>
        <p>
          These earlier idea notes and handoffs are kept as source material for
          the presentation-complexity framework. Some of them may be superseded
          by the article above, but they remain useful historical and research
          context.
        </p>

        <div class="source-list">
          {
            complexitySources.map((source) => (
              <SourceDisclosure
                id={source.id}
                title={source.title}
                english={source.english}
                italian={source.italian}
              />
            ))
          }
        </div>
      </section>
    </article>
  </main>
</BaseLayout>
