---
import { readFileSync } from "node:fs";
import AiAssistedMathNotice from "../../components/AiAssistedMathNotice.astro";
import SectionBackLink from "../../components/SectionBackLink.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const assetBase = "/assets/ai-assisted-math/lef-growth-wreath-products";
const pdfHref = `${assetBase}/lef-growth-wreath-products.pdf`;
const texHref = `${assetBase}/lef-growth-wreath-products.tex`;
const tex = readFileSync(`public${texHref}`, "utf8");

const citeKeys = [
  "Bradford2022",
  "Bradford2026",
  "BouRabeeCornulier2016",
  "BouRabeeStudenmund2016",
  "Cornulier2006",
  "Cornulier2016",
  "Cornulier2016arxiv",
  "Schwartz1980",
  "Zippel1979",
];

const citeNumbers = new Map(citeKeys.map((key, index) => [key, index + 1]));

const abstractSource =
  tex.match(/\\begin\{abstract\}([\s\S]*?)\\end\{abstract\}/)?.[1] ?? "";
const bodySource = tex.slice(
  tex.indexOf("\\section{Introduction}"),
  tex.indexOf("\\begin{thebibliography}")
);
const bibliographySource =
  tex.match(/\\begin\{thebibliography\}\{9\}([\s\S]*?)\\end\{thebibliography\}/)?.[1] ?? "";

const sectionTitlePattern = /\\(section|subsection)(\*)?\{([^}]+)\}/g;
const tocEntries: { level: "section" | "subsection"; number: string; title: string; id: string }[] = [];
let tocSection = 0;
let tocSubsection = 0;
for (const match of bodySource.matchAll(sectionTitlePattern)) {
  const level = match[1] as "section" | "subsection";
  const isStarred = Boolean(match[2]);
  const title = match[3];
  if (isStarred) continue;
  if (level === "section") {
    tocSection += 1;
    tocSubsection = 0;
    tocEntries.push({ level, number: String(tocSection), title, id: slugify(`${tocSection}-${title}`) });
  } else {
    tocSubsection += 1;
    tocEntries.push({
      level,
      number: `${tocSection}.${tocSubsection}`,
      title,
      id: slugify(`${tocSection}-${tocSubsection}-${title}`),
    });
  }
}

const renderState = {
  section: 0,
  subsection: 0,
  theorem: 0,
};

const abstractHtml = renderFragment(abstractSource, { ...renderState });
const bodyHtml = renderFragment(bodySource, renderState);
const bibliographyHtml = renderBibliography(bibliographySource);

function slugify(value: string) {
  return value
    .toLowerCase()
    .replace(/\\\([^)]*\\\)/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");
}

function findEnvironmentEnd(lines: string[], start: number, environment: string) {
  let depth = 0;
  for (let index = start; index < lines.length; index += 1) {
    const line = lines[index];
    if (line.includes(`\\begin{${environment}}`)) depth += 1;
    if (line.includes(`\\end{${environment}}`)) {
      depth -= 1;
      if (depth === 0) return index;
    }
  }
  return start;
}

function renderFragment(source: string, state: typeof renderState): string {
  const lines = source.trim().split(/\r?\n/);
  const html: string[] = [];
  const paragraph: string[] = [];

  const flushParagraph = () => {
    const text = paragraph.join(" ").trim();
    if (text) html.push(`<p>${formatInline(text)}</p>`);
    paragraph.length = 0;
  };

  for (let index = 0; index < lines.length; index += 1) {
    const rawLine = lines[index];
    const line = rawLine.trim();

    if (!line) {
      flushParagraph();
      continue;
    }

    const sectionMatch = line.match(/^\\section(\*)?\{(.+)\}$/);
    if (sectionMatch) {
      flushParagraph();
      const isStarred = Boolean(sectionMatch[1]);
      const title = sectionMatch[2];
      if (isStarred) {
        html.push(`<h2 id="${slugify(title)}">${formatInline(title)}</h2>`);
      } else {
        state.section += 1;
        state.subsection = 0;
        state.theorem = 0;
        html.push(`<h2 id="${slugify(`${state.section}-${title}`)}">${state.section} ${formatInline(title)}</h2>`);
      }
      continue;
    }

    const subsectionMatch = line.match(/^\\subsection\{(.+)\}$/);
    if (subsectionMatch) {
      flushParagraph();
      state.subsection += 1;
      const title = subsectionMatch[1];
      html.push(
        `<h3 id="${slugify(`${state.section}-${state.subsection}-${title}`)}">${state.section}.${state.subsection} ${formatInline(title)}</h3>`
      );
      continue;
    }

    if (line === "\\[") {
      flushParagraph();
      const mathLines = [line];
      while (index + 1 < lines.length) {
        index += 1;
        mathLines.push(lines[index]);
        if (lines[index].trim() === "\\]") break;
      }
      html.push(`<div class="math-display">${mathLines.join("\n")}</div>`);
      continue;
    }

    const environmentMatch = line.match(/^\\begin\{([a-z]+)\}(\[[^\]]+\])?$/);
    if (environmentMatch) {
      flushParagraph();
      const environment = environmentMatch[1];
      const optionalTitle = environmentMatch[2]?.slice(1, -1);
      const end = findEnvironmentEnd(lines, index, environment);
      const inner = lines.slice(index + 1, end).join("\n");
      index = end;

      if (environment === "proof") {
        html.push(`<div class="paper-proof"><p class="paper-proof-label">Proof.</p>${renderFragment(inner, state)}</div>`);
        continue;
      }

      if (environment === "enumerate") {
        html.push(renderEnumerate(inner, state));
        continue;
      }

      const labels: Record<string, string> = {
        theorem: "Theorem",
        proposition: "Proposition",
        lemma: "Lemma",
        corollary: "Corollary",
        definition: "Definition",
        problem: "Problem",
        remark: "Remark",
      };

      const label = labels[environment];
      if (label) {
        state.theorem += 1;
        const title = `${label} ${state.section}.${state.theorem}${optionalTitle ? ` (${optionalTitle})` : ""}.`;
        html.push(
          `<section class="paper-statement"><p class="paper-statement-label">${formatInline(title)}</p>${renderFragment(inner, state)}</section>`
        );
        continue;
      }
    }

    paragraph.push(line);
  }

  flushParagraph();
  return html.join("\n");
}

function renderEnumerate(source: string, state: typeof renderState): string {
  const items = source
    .split(/\\item\s+/)
    .map((item) => item.trim())
    .filter(Boolean);

  return `<ol>${items.map((item) => `<li>${renderFragment(item, state)}</li>`).join("")}</ol>`;
}

function renderBibliography(source: string) {
  const parts = source
    .split(/\\bibitem\{([^}]+)\}/)
    .slice(1);
  const items: string[] = [];

  for (let index = 0; index < parts.length; index += 2) {
    const key = parts[index];
    const content = parts[index + 1]?.trim() ?? "";
    const number = citeNumbers.get(key) ?? items.length + 1;
    items.push(`<li id="ref-${key}" value="${number}">${formatInline(content)}</li>`);
  }

  return `<ol>${items.join("")}</ol>`;
}

function formatInline(value: string) {
  return value
    .replace(/\\noindent\s*/g, "")
    .replace(/\\textbf\{([^{}]+)\}/g, "<strong>$1</strong>")
    .replace(/\\emph\{([^{}]+)\}/g, "<em>$1</em>")
    .replace(/\\cite\{([^}]+)\}/g, (_, keys: string) =>
      keys
        .split(",")
        .map((key) => {
          const trimmedKey = key.trim();
          const number = citeNumbers.get(trimmedKey) ?? "?";
          return `<a href="#ref-${trimmedKey}">[${number}]</a>`;
        })
        .join(", ")
    );
}
---

<BaseLayout
  title="LEF Growth of Wreath Products with Abelian and Virtually Abelian Lamps"
  description="A paper on LEF growth of wreath products with abelian, non-abelian, and virtually abelian lamps."
  currentPath="/ai-assisted-math/lef-growth-wreath-products.html"
  bodyClass="paper-surface"
>
  <script is:inline>
    window.MathJax = {
      tex: {
        inlineMath: [["\\(", "\\)"]],
        displayMath: [["\\[", "\\]"]],
        macros: {
          LEF: "\\mathcal{L}",
          Z: "\\mathbb{Z}",
          F: "\\mathbb{F}",
          N: "\\mathbb{N}",
          R: "\\mathbb{R}",
          rank: "\\operatorname{rank}",
          tors: "\\operatorname{tors}",
          supp: "\\operatorname{supp}",
          Aut: "\\operatorname{Aut}",
          Sym: "\\operatorname{Sym}",
          diam: "\\operatorname{diam}",
        },
      },
    };
  </script>
  <script is:inline async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js"></script>

  <main class="shell article-shell">
    <article class="plain-page ai-article paper-page">
      <SectionBackLink href="/ai-assisted-math.html" label="Back to AI-assisted math" />
      <AiAssistedMathNotice />

      <header class="plain-header paper-header">
        <div class="article-meta">
          <time datetime="2026-06">June 2026</time>
        </div>
        <h1>LEF Growth of Wreath Products with Abelian and Virtually Abelian Lamps</h1>
        <p class="paper-author">Luca Blanchi</p>
        <div class="paper-actions" aria-label="Downloads">
          <a href={pdfHref} download>Download PDF</a>
          <a href={texHref} download>Download TeX</a>
        </div>
      </header>

      <section class="paper-abstract" aria-labelledby="abstract-title">
        <h2 id="abstract-title">Abstract</h2>
        <div set:html={abstractHtml} />
      </section>

      <nav class="paper-toc" aria-labelledby="contents-title">
        <h2 id="contents-title">Contents</h2>
        <ol>
          {
            tocEntries.map((entry) => (
              <li class={entry.level === "subsection" ? "paper-toc-subsection" : undefined}>
                <a href={`#${entry.id}`}>
                  <span>{entry.number}</span>
                  {entry.title}
                </a>
              </li>
            ))
          }
        </ol>
      </nav>

      <div class="paper-body" set:html={bodyHtml} />

      <section class="paper-references" aria-labelledby="references-title">
        <h2 id="references-title">References</h2>
        <div set:html={bibliographyHtml} />
      </section>
    </article>
  </main>
</BaseLayout>
