---
import { readFileSync } from "node:fs";
import AiAssistedMathNotice from "../../components/AiAssistedMathNotice.astro";
import SectionBackLink from "../../components/SectionBackLink.astro";
import TexPaperDocument from "../../components/TexPaperDocument.astro";
import { renderTexPaper } from "../../lib/texPaper";
import BaseLayout from "../../layouts/BaseLayout.astro";

const assetBase = "/assets/ai-assisted-math/previous-copy-parsing";
const stem = "finite-stammering-profiles-tube-barriers";
const paper = renderTexPaper(readFileSync(`public${assetBase}/${stem}.tex`, "utf8"), {
  idPrefix: "stammering",
});

const assets = [
  { label: "Download PDF", href: `${assetBase}/${stem}.pdf` },
  { label: "Download TeX", href: `${assetBase}/${stem}.tex` },
];
---

<BaseLayout
  title="Previous-Copy Compression: Quantitative Barriers"
  description="Advanced quantitative notes on finite stammering profiles and tube barriers for algebraic digit expansions."
  currentPath="/ai-assisted-math/previous-copy-compression-quantitative-barriers.html"
  bodyClass="paper-surface"
>
  <script is:inline>
    window.MathJax = {
      tex: {
        inlineMath: [["\\(", "\\)"], ["$", "$"]],
        displayMath: [["\\[", "\\]"]],
        macros: {
          oc: "\\operatorname{oc}",
          normZ: ["\\left|#1\\right|_{\\mathbb Z}", 1],
        },
      },
    };
  </script>
  <script is:inline async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js"></script>

  <main class="shell article-shell">
    <article class="plain-page ai-article paper-page">
      <SectionBackLink href="/ai-assisted-math.html" label="Back to AI-assisted math" />
      <AiAssistedMathNotice />

      <header class="plain-header paper-header paper-collection-header">
        <div class="article-meta">
          <time datetime="2026-06">June 2026</time>
        </div>
        <h1>Previous-Copy Compression: Quantitative Barriers</h1>
        <p>
          This advanced continuation isolates finite stammering profiles,
          exponential tube barriers, and conditional quantitative consequences.
        </p>
      </header>

      <TexPaperDocument paper={paper} assets={assets} eyebrow="Part II" />
    </article>
  </main>
</BaseLayout>
