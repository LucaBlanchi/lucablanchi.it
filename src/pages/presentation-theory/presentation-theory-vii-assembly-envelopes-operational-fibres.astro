---
import { readFileSync } from "node:fs";
import GenerativeAiNotice from "../../components/GenerativeAiNotice.astro";
import PreliminaryStatusNotice from "../../components/PreliminaryStatusNotice.astro";
import SectionBackLink from "../../components/SectionBackLink.astro";
import { renderTexPaper } from "../../lib/texPaper";
import BaseLayout from "../../layouts/BaseLayout.astro";

const assetBase = "/assets/presentation-theory/presentation-theory-vii-assembly-envelopes-operational-fibres";
const stem = "presentation-theory-vii-assembly-envelopes-operational-fibres";
const paper = renderTexPaper(readFileSync(`public${assetBase}/${stem}.tex`, "utf8"), {
  idPrefix: "presentation-theory-vii",
});

const pdfHref = `${assetBase}/${stem}.pdf`;
const texHref = `${assetBase}/${stem}.tex`;
---

<BaseLayout
  title="Presentation Theory VII: Assembly Envelopes and Operational Fibres"
  description="Operations as presentation engines: assembly envelopes, operational image filtrations, decomposition fibres, bridge costs, observable barriers, and verification records."
  currentPath="/presentation-theory/presentation-theory-vii-assembly-envelopes-operational-fibres.html"
  bodyClass="paper-surface"
>
  <script is:inline>
    window.MathJax = {
      tex: {
        inlineMath: [["\\(", "\\)"], ["$", "$"]],
        displayMath: [["\\[", "\\]"]],
      },
    };
  </script>
  <script is:inline async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js"></script>

  <main class="shell article-shell">
    <article class="plain-page ai-article paper-page paper-page-light-statements">
      <SectionBackLink href="/presentation-theory.html" label="Back to Presentation theory" />
      <GenerativeAiNotice />
      <PreliminaryStatusNotice />

      <header class="plain-header paper-header">
        <div class="article-meta">
          <time datetime="2026-06">June 2026</time>
        </div>
        <h1>{paper.title}</h1>
        <p class="paper-author">{paper.author}</p>
        <div class="paper-actions" aria-label="Downloads">
          <a href={pdfHref} download>Download PDF</a>
          <a href={texHref} download>Download TeX</a>
        </div>
      </header>

      <section class="paper-abstract" aria-labelledby="abstract-title">
        <h2 id="abstract-title">Abstract</h2>
        <div set:html={paper.abstractHtml} />
      </section>

      <nav class="paper-toc" aria-labelledby="contents-title">
        <h2 id="contents-title">Contents</h2>
        <ol>
          {
            paper.tocEntries.map((entry) => (
              <li class={entry.level === "subsection" ? "paper-toc-subsection" : undefined}>
                <a href={`#${entry.id}`}>
                  <span>{entry.number}</span>
                  {entry.title}
                </a>
              </li>
            ))
          }
        </ol>
      </nav>

      <div class="paper-body" set:html={paper.bodyHtml} />

      <section class="paper-references" aria-label={`${paper.title} references`}>
        <h2>References</h2>
        <div set:html={paper.bibliographyHtml} />
      </section>
    </article>
  </main>
</BaseLayout>
