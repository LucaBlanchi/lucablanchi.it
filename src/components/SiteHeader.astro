---
interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
const isHomePage = currentPath === "/";
const isDraftsPage = currentPath === "/drafts.html" || currentPath.startsWith("/drafts/");
const isPresentationTheoryPage =
  currentPath === "/presentation-theory.html" || currentPath.startsWith("/presentation-theory/");
const isLifeSimulationPage = currentPath === "/life-simulation.html";
---

<header class="top-nav">
  <div class="shell nav-shell">
    <a class="brand-link" href="/" aria-current={isHomePage ? "page" : undefined}>Home</a>
    <nav class="nav-links" aria-label="Main navigation">
      <a href="/drafts.html" aria-current={isDraftsPage ? "page" : undefined}>Draft concepts</a>
      <a href="/presentation-theory.html" aria-current={isPresentationTheoryPage ? "page" : undefined}>Presentation theory</a>
      <a href="/life-simulation.html" aria-current={isLifeSimulationPage ? "page" : undefined}>Life simulation</a>
    </nav>
  </div>
</header>
