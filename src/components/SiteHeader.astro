---
interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
const isHomePage = currentPath === "/";
const isDraftsPage = currentPath === "/drafts.html" || currentPath.startsWith("/drafts/");
const isAiMathPage =
  currentPath === "/ai-assisted-math.html" || currentPath.startsWith("/ai-assisted-math/");
---

<header class="top-nav">
  <div class="shell nav-shell">
    <a class="brand-link" href="/" aria-current={isHomePage ? "page" : undefined}>Home</a>
    <nav class="nav-links" aria-label="Main navigation">
      <a href="/drafts.html" aria-current={isDraftsPage ? "page" : undefined}>Draft concepts</a>
      <a href="/ai-assisted-math.html" aria-current={isAiMathPage ? "page" : undefined}>Presentation theory</a>
    </nav>
  </div>
</header>
